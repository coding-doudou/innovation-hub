# Copy to .env (local dev) or set as GitHub Actions "Variables" (production build).
# Leave everything blank to run on browser localStorage with no Azure setup.
#
# These are NOT secrets — a browser SPA exposes them in the bundle. Access is
# protected by Entra ID sign-in + the redirect-URI allowlist + Graph permissions.

# Entra ID (Azure AD) app registration — SPA platform
VITE_AAD_CLIENT_ID=
VITE_AAD_TENANT_ID=
# Optional. Defaults to the page URL the app is served from. Must be registered
# as a redirect URI on the app registration, e.g. https://you.github.io/repo/
VITE_AAD_REDIRECT_URI=

# SharePoint site that holds the two lists
VITE_SP_HOSTNAME=contoso.sharepoint.com
VITE_SP_SITE_PATH=/sites/InnovationHub
VITE_SP_PROJECTS_LIST=Projects
VITE_SP_DECISIONS_LIST=Decisions

# Optional override: force "local" or "sharepoint". Auto-detected when omitted.
VITE_DATA_BACKEND=

# --- AI (MIDAS Vibe Gateway) ---
# In a DEPLOYED build, point this at the server-side proxy so the browser never
# holds the gateway key. On Azure Static Web Apps this is just "/api/chat".
# Leave blank for local dev (falls back to a per-browser key set in Settings).
VITE_AI_PROXY_URL=
# Optional default model so users don't each type it (e.g. claude-3-sonnet).
VITE_AI_MODEL=
#
# NOTE: the gateway key itself is NOT a VITE_ var (those ship to the browser).
# Set it as a server-only app setting on the backend: VIBE_API_KEY and
# VIBE_BASE_URL (see DEPLOY-AZURE.md).
